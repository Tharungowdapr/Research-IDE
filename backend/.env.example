# ── App ──────────────────────────────────────────────────────────
APP_NAME=ResearchIDE
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── Database ──────────────────────────────────────────────────────
# SQLite (development — no setup needed)
DATABASE_URL=sqlite:///./research_ide.db

# PostgreSQL (production — uncomment and configure)
# DATABASE_URL=postgresql://user:password@localhost:5432/research_ide

# ── Security ──────────────────────────────────────────────────────
# CHANGE THESE IN PRODUCTION — use long random strings
SECRET_KEY=dev-secret-key-change-in-production-minimum-32-chars
ENCRYPTION_KEY=dev-encryption-key-change-in-production!

# ── LLM Default Settings ─────────────────────────────────────────
DEFAULT_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# ── CORS ─────────────────────────────────────────────────────────
# Add your frontend URL here in production
# ALLOWED_ORIGINS=["https://your-domain.com"]
